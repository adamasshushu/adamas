{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@adamas/core": ["./packages/core/src"],
      "@adamas/tools": ["./packages/tools/src"],
      "@adamas/gateway": ["./packages/gateway/src"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/cli/*.ts"],
  "exclude": ["node_modules", "dist", "target"]
}
